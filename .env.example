# ---- Aurio configuration ----
# Copy this file to ".env" and fill in your values. Everything is optional;
# any feature whose keys are missing simply stays disabled and the app still runs.

# Local server port (the PWA + API live here)
PORT=8080

# By default the control API + live WebSocket are localhost-only; only the static
# player and read-only media proxies are reachable from the LAN (so UPnP speakers
# can fetch audio while casting). Set to true to open the whole API to the LAN —
# ONLY behind your own auth / reverse proxy on a trusted network.
AURIO_ALLOW_LAN=false

# ---- Brain: the AI that DJs for you ----
# Everything here is also editable in-app (设置 → 大脑 · AI). Two ways to connect:
#
# A) A local coding CLI (uses ITS OWN login — no key stored here):
#      AI_PROVIDER=claude   # or: codex | cli (custom binary in AI_CLI_BIN)
CLAUDE_BIN=claude
AI_CLI_BIN=
# Optional: pin a model, e.g. claude-opus-4-8 / claude-sonnet-4-6
CLAUDE_MODEL=
# Set to true if you hit "401 Invalid bearer token": forces your stored Claude
# Code login by ignoring any ANTHROPIC_API_KEY/AUTH_TOKEN in the env.
CLAUDE_FORCE_LOGIN=false
#
# B) A hosted model via API key (GLM/智谱, DeepSeek, Kimi, OpenAI, Anthropic…):
#      AI_PROVIDER=api
#      AI_API_KIND=openai           # 'openai'-compatible | 'anthropic'
#      AI_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4   # GLM example (no /v1)
#      AI_API_MODEL=glm-4-flash
#      AI_API_KEY=...
AI_PROVIDER=
AI_API_KIND=
AI_API_BASE_URL=
AI_API_MODEL=
AI_API_KEY=

# Post-generation LLM judge for scheduled on-air lines (one extra brain call
# per spoken break; the deterministic rule judge always runs). off to disable.
AURIO_LLM_JUDGE=on

# ---- Music source 1: Navidrome (Subsonic API) ----
# 可留空：首次启动会在应用内弹出引导，填写并测试连接后自动保存（存到 data/settings.json）。
NAVIDROME_URL=
NAVIDROME_USER=
NAVIDROME_PASS=

# ---- Music source 2: NetEase Cloud Music (built-in) ----
# Search works out of the box; scan-to-login (in 设置 → 网易云) unlocks playback
# + daily picks. NETEASE_COOKIE/REAL_IP are filled automatically — leave blank.
# (REAL_IP is a stable China-mainland IP used to avoid the "设备环境异常" block.)
NETEASE_COOKIE=
NETEASE_REAL_IP=

# ---- Music source 3: QQ Music (built-in) ----
# Search and lyrics work out of the box. Playback follows QQ's vkey entitlement;
# copyrighted/VIP tracks may need a valid QQ_COOKIE. QQ_API_URL is optional and
# only used as a fallback if you run a compatible self-hosted QQMusicApi.
QQ_COOKIE=
QQ_API_URL=

# ---- Voice / TTS ----
# Default is local macOS system speech (no key). Switch in-app or set:
#   VOICE_PROVIDER=system   # system | tencent | fish | doubao
VOICE_PROVIDER=system
SYSTEM_TTS_VOICE=Tingting

# Tencent Cloud TTS (domestic cloud option)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_TTS_REGION=ap-guangzhou
TENCENT_TTS_VOICE_TYPE=1001

# 豆包语音 / Volcano Engine Doubao TTS (emotional Chinese radio voices; appid +
# access token from console.volcengine.com → 语音技术 → 语音合成大模型)
DOUBAO_TTS_APPID=
DOUBAO_TTS_TOKEN=
# Default voice is 深夜播客 (warm late-night podcast); see the 音色列表 doc for more
DOUBAO_TTS_VOICE_TYPE=zh_male_shenyeboke_emo_v2_mars_bigtts
# 0.8–2.0; slightly slow suits short between-song breaks at night
DOUBAO_TTS_SPEED=0.9
# Optional emotion for multi-emotion (emo_v2) voices (e.g. happy / sad / coldness);
# empty = the voice's own register, which for 深夜播客 already is late-night radio
DOUBAO_TTS_EMOTION=
DOUBAO_TTS_CLUSTER=volcano_tts

# Fish Audio fallback
FISH_API_KEY=
FISH_REFERENCE_ID=
FISH_MODEL=s2-pro
FISH_API_BASE_URL=https://api.fish.audio

# ---- Weather: OpenWeather ----
OPENWEATHER_KEY=
WEATHER_LAT=
WEATHER_LON=
WEATHER_CITY=

# ---- Calendars (pluggable) ----
# macOS system Calendar works through the in-app "检查本机日历" button.
# You can also import .ics files in-app or provide subscription URLs here.
CALENDAR_ICS_URLS=
CALENDAR_ICS_FILES=
# Feishu / Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CALENDAR_ID=primary
# DingTalk
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# WeCom (企业微信)
WECOM_CORP_ID=
WECOM_SECRET=
WECOM_AGENT_ID=
