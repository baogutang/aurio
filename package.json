{
  "name": "aurio",
  "version": "0.2.3",
  "description": "Aurio - your personal AI radio. Cross-platform (macOS + Windows).",
  "type": "module",
  "main": "electron/main.js",
  "author": "niko <niko@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baogutang/aurio.git"
  },
  "homepage": "https://github.com/baogutang/aurio#readme",
  "bugs": {
    "url": "https://github.com/baogutang/aurio/issues"
  },
  "scripts": {
    "server": "node server/index.js",
    "start": "electron .",
    "dev": "electron .",
    "postinstall": "node scripts/patch-netease-cloud.js",
    "test": "vitest run",
    "build:web": "npm --prefix web run build",
    "typecheck:web": "npm --prefix web run typecheck",
    "audit:prod": "npm audit --omit=dev && npm --prefix web audit --omit=dev",
    "ci": "npm run typecheck:web && npm test && npm run build:web",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "NeteaseCloudMusicApi": "^4.32.0",
    "node-cron": "^4.5.0",
    "node-ical": "^0.26.1",
    "electron-updater": "^6.8.9",
    "upnp-mediarenderer-client": "^1.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "41.7.1",
    "electron-builder": "^26.15.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "NeteaseCloudMusicApi": {
      "music-metadata": "^11.12.2"
    }
  },
  "build": {
    "appId": "studio.niko.aurio",
    "productName": "Aurio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "baogutang",
        "repo": "aurio"
      }
    ],
    "files": [
      "electron/**/*",
      "server/**/*",
      "pwa/**/*",
      "prompts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "user",
        "to": "user"
      },
      {
        "from": ".env.example",
        "to": ".env.example"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    },
    "linux": {
      "category": "Audio",
      "maintainer": "niko <niko@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "directories": {
      "output": "release"
    }
  }
}
